# Veles — пример секретов для Streamlit
#
# Streamlit Community Cloud:
#   share.streamlit.io → ваше приложение → Settings → Secrets
#   Скопируйте содержимое (без комментариев #) в редактор секретов.
#
# Локально (опционально):
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   Файл .streamlit/secrets.toml не коммитится (.gitignore).

# --- Авторизация (прототип) ---
VELES_AUTH_USER = "admin"
VELES_AUTH_PASSWORD = "change-me"

# --- PostgreSQL (обязательно для облака) ---
# Локально: docker compose + docker-compose.yml
# Облако: Neon, Supabase, Railway и т.п.
# Формат: postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL = "postgresql+psycopg://veles:veles_secret@localhost:5432/veles"

# --- Diadoc (опционально) ---
DIADOC_API_URL = "https://diadoc-api-staging.kontur.ru"
DIADOC_CLIENT_ID = ""
DIADOC_ACCESS_TOKEN = ""
# Ящики через запятую; если пусто — из GetMyOrganizations
DIADOC_BOX_IDS = ""

# --- Аванкор (опционально) ---
AVANKOR_BASE_URL = ""

# --- Ollama — только локально, на Streamlit Cloud не работает ---
OLLAMA_HOST = "http://127.0.0.1:11434"
OLLAMA_MODEL = "veles-vl"
OLLAMA_NUM_CTX = "4096"
