# Veles — пример переменных окружения (скопируйте в .env)

VELES_AUTH_USER=admin
VELES_AUTH_PASSWORD=admin

DIADOC_API_URL=https://diadoc-api-staging.kontur.ru
DIADOC_CLIENT_ID=
DIADOC_ACCESS_TOKEN=
# Ящики Diadoc через запятую (если пусто — берутся из GetMyOrganizations)
DIADOC_BOX_IDS=

AVANKOR_BASE_URL=

# Ollama — распознавание PDF (см. scripts/setup-ollama-gpu.sh)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=veles-vl
OLLAMA_NUM_CTX=2048

# PostgreSQL (см. docker-compose.yml)
DATABASE_URL=postgresql+psycopg://veles:veles_secret@localhost:5432/veles
